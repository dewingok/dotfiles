Host * 
    ForwardAgent yes
    ServerAliveInterval 60
    ServerAliveCountMax 4
    VerifyHostKeyDNS ask
    IdentityFile ~/.ssh/id_ed25519
    # UseKeychain yes
    AddKeysToAgent yes
    ControlMaster auto
    ControlPath ~/.ssh/control:%h:%p:%r

Host gh
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_dewingok

Host eqix
  Hostname github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_eqix
